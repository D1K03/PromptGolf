# Redis (Upstash) — required
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Image generation (fal.ai) — required for /api/generate
FAL_KEY=

# Realtime (Pusher) — required for room presence + game events
PUSHER_APP_ID=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# LLM for commentary — stretch (voice commentary feature)
ANTHROPIC_API_KEY=

# Voice commentary — stretch
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# App
NEXT_PUBLIC_APP_URL=

# Target image generation script (src/app/_scripts/generate-targets.ts)
# Only needed when running the script locally to seed /public/targets
GCP_PROJECT_ID=
GCP_LOCATION=europe-west2
GCP_GEMINI_MODEL=gemini-2.0-flash-001
PROMPTS_PER_CATEGORY=5
